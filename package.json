{
  "name": "superclaw-pure",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @superclaw/server dev",
    "dev:web": "pnpm --filter @superclaw/web dev",
    "build": "pnpm --filter @superclaw/web build && pnpm --filter @superclaw/server build",
    "build:web": "NEXT_OUTPUT=export pnpm --filter @superclaw/web build",
    "build:server": "pnpm --filter @superclaw/server build",
    "start": "NODE_ENV=production node apps/server/dist/index.js",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "test": "pnpm --filter @superclaw/server test"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
